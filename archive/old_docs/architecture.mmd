%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#4A90D9', 'primaryTextColor': '#fff', 'lineColor': '#5C6BC0', 'secondaryColor': '#E8EAF6' } } }%%
graph TD

    %% ===== Data Layer =====
    subgraph DATA["Data Layer / 数据层 (data/)"]
        direction TB
        DF["data_fetcher.py<br/>价格数据 OHLCV<br/>yfinance + 本地缓存"]
        FF["fundamental_fetcher.py<br/>基本面 PE/PB/ROE<br/>分析师评级"]
        HF["historical_fundamentals.py<br/>历史季度财报<br/>修复前视偏差"]
        HN["historical_news.py<br/>HuggingFace 新闻情绪<br/>关键词匹配"]
        LN["live_news_sentiment.py<br/>实时新闻情绪<br/>Haiku API (未启用)"]
    end

    %% ===== Strategy Layer =====
    subgraph STRATEGY["Strategy Layer / 策略层 (strategy/)"]
        direction TB
        MOM["momentum.py<br/>6个月动量 + 200DMA"]
        RF["regime_filter.py<br/>跨资产市场环境<br/>SPY SMA 55% | 收益率曲线 15%<br/>VIX 15% | 信用利差 15%"]
        ES["earnings_surprise.py<br/>PEAD 盈利惊喜因子"]
        IS["insider_signal.py<br/>SEC Form 4<br/>集群买入信号"]
        PS["portfolio_strategy.py<br/>组合选股 + 评分<br/>3档配置"]
    end

    %% ===== Scoring =====
    subgraph SCORING["综合评分"]
        SC["基本面 50% + 动量 30% + 分析师 20%<br/>+ Earnings 调整 + Insider 加分"]
    end

    %% ===== Regime =====
    subgraph REGIME["仓位管理"]
        RM["BULL = 100% 满仓<br/>CAUTION = 50% 半仓<br/>BEAR = 25% 仓位"]
    end

    %% ===== Portfolio =====
    subgraph PORTFOLIO["组合构建"]
        PB["Top N 选股 + 等权分配<br/>SPY 底仓 20%<br/>Trailing Stop 25%"]
    end

    %% ===== Backtest Layer =====
    subgraph BACKTEST["Backtest Layer / 回测层 (backtest/)"]
        BT["portfolio_backtester.py<br/>组合级回测引擎"]
    end

    %% ===== Execution Layer =====
    subgraph EXEC["Execution Layer / 执行层 (scripts)"]
        DS["run_daily_signals.py<br/>每日选股信号"]
        PT["run_paper_trading.py<br/>Paper Trading<br/>信号 + 回顾"]
        V3["run_portfolio_validation_v3.py<br/>V3 回测 2018-2025"]
        BT2526["run_backtest_2025_2026.py<br/>近期回测"]
        OOS["run_oos_test.py<br/>样本外测试"]
    end

    %% ===== Output =====
    subgraph OUTPUT["Output / 输出"]
        RPT["reports/<br/>JSON 报告"]
        TG["Telegram 推送<br/>(计划中)"]
    end

    %% ===== Data -> Strategy flows =====
    DF --> MOM
    DF --> RF
    FF --> PS
    HF --> PS
    HF --> ES
    HN --> PS
    LN -.-> PS

    %% ===== Strategy internal flows =====
    MOM --> SC
    FF --> SC
    ES --> SC
    IS --> SC
    PS --> SC

    %% ===== Scoring -> Regime -> Portfolio =====
    SC --> RM
    RF --> RM
    RM --> PB

    %% ===== Portfolio -> Execution =====
    PB --> DS
    PB --> PT
    PB --> BT

    %% ===== Backtest feeds execution =====
    BT --> V3
    BT --> BT2526
    BT --> OOS

    %% ===== Execution -> Output =====
    DS --> RPT
    PT --> RPT
    V3 --> RPT
    BT2526 --> RPT
    OOS --> RPT
    DS -.-> TG

    %% ===== Styles =====
    classDef dataStyle fill:#4CAF50,stroke:#2E7D32,color:#fff,stroke-width:2px
    classDef stratStyle fill:#2196F3,stroke:#1565C0,color:#fff,stroke-width:2px
    classDef scoreStyle fill:#FF9800,stroke:#E65100,color:#fff,stroke-width:2px
    classDef regimeStyle fill:#9C27B0,stroke:#6A1B9A,color:#fff,stroke-width:2px
    classDef portfolioStyle fill:#00BCD4,stroke:#00838F,color:#fff,stroke-width:2px
    classDef backtestStyle fill:#795548,stroke:#4E342E,color:#fff,stroke-width:2px
    classDef execStyle fill:#607D8B,stroke:#37474F,color:#fff,stroke-width:2px
    classDef outputStyle fill:#F44336,stroke:#C62828,color:#fff,stroke-width:2px

    class DF,FF,HF,HN,LN dataStyle
    class MOM,RF,ES,IS,PS stratStyle
    class SC scoreStyle
    class RM regimeStyle
    class PB portfolioStyle
    class BT backtestStyle
    class DS,PT,V3,BT2526,OOS execStyle
    class RPT,TG outputStyle

    style DATA fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px
    style STRATEGY fill:#E3F2FD,stroke:#2196F3,stroke-width:2px
    style SCORING fill:#FFF3E0,stroke:#FF9800,stroke-width:2px
    style REGIME fill:#F3E5F5,stroke:#9C27B0,stroke-width:2px
    style PORTFOLIO fill:#E0F7FA,stroke:#00BCD4,stroke-width:2px
    style BACKTEST fill:#EFEBE9,stroke:#795548,stroke-width:2px
    style EXEC fill:#ECEFF1,stroke:#607D8B,stroke-width:2px
    style OUTPUT fill:#FFEBEE,stroke:#F44336,stroke-width:2px
